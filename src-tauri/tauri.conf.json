{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dictate",
  "version": "0.1.0",
  "identifier": "com.pedro.dictate",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Dictate",
        "width": 920,
        "height": 720,
        "minWidth": 760,
        "minHeight": 600,
        "resizable": true,
        "visible": false,
        "center": true
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "width": 220,
        "height": 60,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "visible": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "resources": ["binaries/*"]
  }
}
